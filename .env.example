# Copy to .env.local or another ignored file. Never commit real secrets.
HINA_HOST=127.0.0.1
HINA_LOG_LEVEL=INFO
HINA_PROFILE=development

# M04 speech input. CPU int8 is the safe default on Windows.
HINA_STT_MODEL=Systran/faster-whisper-small
HINA_STT_MODEL_REVISION=536b0662742c02347bc0e980a01041f333bce120
HINA_STT_MODEL_CACHE=var/cache/models/faster-whisper
HINA_STT_DEVICE=cpu
HINA_STT_COMPUTE_TYPE=int8
HINA_STT_ALLOW_DOWNLOAD=true
HINA_STT_CPU_FALLBACK=true
HINA_STT_CPU_THREADS=8
HINA_STT_BEAM_SIZE=1
HINA_STT_TIMEOUT_SECONDS=90

# M05 Vietnamese speech output. VieNeu ONNX int8 runs on CPU by default.
HINA_TTS_MODEL=pnnbao-ump/VieNeu-TTS-v3-Turbo
HINA_TTS_MODEL_REVISION=75ff82a72f54d55ed389e1eeb12041d3c4bac7d4
HINA_TTS_CODEC=OpenMOSS-Team/MOSS-Audio-Tokenizer-Nano-ONNX
HINA_TTS_CODEC_REVISION=ceff0d0749bfb3fa2d61149794ec6feef0d1e1ae
HINA_TTS_MODEL_CACHE=var/cache/models/vieneu
HINA_TTS_DEVICE=cpu
HINA_TTS_PRECISION=int8
HINA_TTS_VOICE=Trúc Ly
HINA_TTS_STYLE=tu_nhien
HINA_TTS_ALLOW_DOWNLOAD=true
HINA_TTS_CPU_THREADS=8
HINA_TTS_TIMEOUT_SECONDS=180
HINA_TTS_MAX_PENDING=2
HINA_TTS_MAX_TEXT_CHARACTERS=2000
HINA_TTS_MAX_CHUNK_CHARACTERS=256
HINA_TTS_MAX_AUDIO_SECONDS=120
