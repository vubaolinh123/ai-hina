{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "rootDir": "electron",
    "outDir": "dist-electron",
    "sourceMap": false,
    "declaration": false
  },
  "include": ["electron/**/*.ts"]
}
