{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/contracts/v1/event-envelope.schema.json",
  "title": "EventEnvelopeV1Base",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "type",
    "scope",
    "sessionId",
    "turnId",
    "correlationId",
    "causationId",
    "source",
    "trustLevel",
    "occurredAt",
    "expiresAt",
    "deadline",
    "idempotencyKey",
    "streamId",
    "sequence",
    "media",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "eventId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "type": {
      "type": "string",
      "pattern": "^hina\\.[a-z0-9_.]+\\.v[1-9][0-9]*(?![\\s\\S])"
    },
    "scope": {
      "enum": [
        "global",
        "session",
        "turn"
      ]
    },
    "sessionId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "turnId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "correlationId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "causationId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u00ad\\u034f\\u061c\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]+(?![\\s\\S])"
    },
    "trustLevel": {
      "enum": [
        "authenticated",
        "owner",
        "public",
        "trusted_local",
        "untrusted"
      ]
    },
    "occurredAt": {
      "type": "string",
      "pattern": "^(?:(?:(?!0000)[0-9]{4}-(?:(?:01|03|05|07|08|10|12)-(?:0[1-9]|[12][0-9]|3[01])|(?:04|06|09|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8])))|(?:(?!0000)(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:[02468][048]|[13579][26])00)-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,6})?Z(?![\\s\\S])"
    },
    "expiresAt": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^(?:(?:(?!0000)[0-9]{4}-(?:(?:01|03|05|07|08|10|12)-(?:0[1-9]|[12][0-9]|3[01])|(?:04|06|09|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8])))|(?:(?!0000)(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:[02468][048]|[13579][26])00)-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,6})?Z(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "deadline": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^(?:(?:(?!0000)[0-9]{4}-(?:(?:01|03|05|07|08|10|12)-(?:0[1-9]|[12][0-9]|3[01])|(?:04|06|09|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8])))|(?:(?!0000)(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:[02468][048]|[13579][26])00)-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,6})?Z(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotencyKey": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u00ad\\u034f\\u061c\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]+(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "streamId": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u00ad\\u034f\\u061c\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]+(?![\\s\\S])"
        },
        {
          "type": "null"
        }
      ]
    },
    "sequence": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "media": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "https://ai-hina.local/contracts/v1/media-reference.schema.json"
      }
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "global"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "sessionId": {
            "type": "null"
          },
          "turnId": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "session"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "sessionId": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
          },
          "turnId": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "turn"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "properties": {
          "sessionId": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
          },
          "turnId": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
          }
        }
      }
    }
  ],
  "$defs": {
    "boundedToken": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u00ad\\u034f\\u061c\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]+(?![\\s\\S])"
    },
    "rfc3339Utc": {
      "type": "string",
      "pattern": "^(?:(?:(?!0000)[0-9]{4}-(?:(?:01|03|05|07|08|10|12)-(?:0[1-9]|[12][0-9]|3[01])|(?:04|06|09|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8])))|(?:(?!0000)(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:[02468][048]|[13579][26])00)-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,6})?Z(?![\\s\\S])"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    }
  }
}
