{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/contracts/v1/catalog.schema.json",
  "title": "ContractCatalogV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "catalogVersion",
    "events",
    "namespace"
  ],
  "properties": {
    "$schema": {
      "const": "https://ai-hina.local/contracts/v1/catalog.schema.json"
    },
    "catalogVersion": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+$"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "name",
          "schema",
          "scope"
        ],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
          },
          "name": {
            "type": "string",
            "pattern": "^hina\\.[a-z0-9_.]+\\.v[1-9][0-9]*$"
          },
          "schema": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^schemas/v1/events/[a-z0-9_.]+\\.schema\\.json$"
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "enum": [
                "global",
                "session",
                "turn"
              ]
            }
          }
        }
      }
    },
    "namespace": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^https://ai-hina\\.local/contracts/v[1-9][0-9]*/$"
    }
  }
}
