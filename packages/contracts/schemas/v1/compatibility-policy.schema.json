{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/contracts/v1/compatibility-policy.schema.json",
  "title": "CompatibilityPolicyV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "catalogVersion",
    "currentMajor",
    "currentMinor",
    "disposition",
    "migrationRequired",
    "previousVersions",
    "supportedPreviousMajorVersions"
  ],
  "properties": {
    "$schema": {
      "const": "https://ai-hina.local/contracts/v1/compatibility-policy.schema.json"
    },
    "catalogVersion": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+$"
    },
    "currentMajor": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "currentMinor": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "disposition": {
      "enum": [
        "initial_release",
        "compatible",
        "migration_required",
        "unsupported"
      ]
    },
    "migrationRequired": {
      "type": "boolean"
    },
    "previousVersions": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "catalogVersion",
          "disposition",
          "migrationRequired"
        ],
        "properties": {
          "catalogVersion": {
            "type": "string",
            "pattern": "^[1-9][0-9]*\\.[0-9]+$"
          },
          "disposition": {
            "enum": [
              "compatible",
              "migration_required",
              "unsupported"
            ]
          },
          "migrationRequired": {
            "type": "boolean"
          }
        }
      }
    },
    "supportedPreviousMajorVersions": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "disposition": {
            "const": "initial_release"
          }
        },
        "required": [
          "disposition"
        ]
      },
      "then": {
        "properties": {
          "migrationRequired": {
            "const": false
          },
          "previousVersions": {
            "maxItems": 0
          },
          "supportedPreviousMajorVersions": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
