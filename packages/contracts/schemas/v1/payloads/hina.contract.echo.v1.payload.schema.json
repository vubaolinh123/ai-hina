{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/contracts/v1/payloads/hina.contract.echo.v1.payload.schema.json",
  "title": "HinaContractEchoV1Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message",
    "locale",
    "tags",
    "metadata"
  ],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1048000
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-[A-Z]{2})?(?![\\s\\S])"
    },
    "tags": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[^\\u0000-\\u001f\\u007f]+(?![\\s\\S])"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          {
            "type": "null"
          },
          {
            "type": "string"
          }
        ]
      },
      "maxProperties": 16
    }
  }
}
