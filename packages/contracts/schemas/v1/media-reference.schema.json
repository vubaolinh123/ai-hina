{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/contracts/v1/media-reference.schema.json",
  "title": "MediaReference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mediaId",
    "kind",
    "mimeType",
    "byteLength",
    "sha256",
    "transportCorrelationId"
  ],
  "properties": {
    "mediaId": {
      "type": "string",
      "pattern": "^media_[a-z0-9][a-z0-9_.-]{0,127}(?![\\s\\S])"
    },
    "kind": {
      "enum": [
        "audio",
        "binary",
        "image",
        "video"
      ]
    },
    "mimeType": {
      "type": "string",
      "maxLength": 129,
      "pattern": "^[a-z0-9][a-z0-9!#$&^_.+-]{0,63}/[a-z0-9][a-z0-9!#$&^_.+-]{0,63}(?![\\s\\S])"
    },
    "byteLength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}(?![\\s\\S])"
    },
    "transportCorrelationId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    }
  }
}
