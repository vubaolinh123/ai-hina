{
  "openapi": "3.1.0",
  "info": {
    "title": "Hina local control plane",
    "version": "1.0.0",
    "description": "Loopback-only read control surface for the Hina core runtime."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8765"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Runtime readiness and bounded connection status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "Build and protocol versions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Version"
                }
              }
            }
          }
        }
      }
    },
    "/v1/config": {
      "get": {
        "operationId": "getPublicConfig",
        "responses": {
          "200": {
            "description": "Non-secret effective transport limits.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicConfig"
                }
              }
            }
          }
        }
      }
    },
    "/v1/metrics": {
      "get": {
        "operationId": "getMetrics",
        "responses": {
          "200": {
            "description": "Bounded in-memory runtime metric snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/v1/model/status": {
      "get": {
        "operationId": "getModelGatewayStatus",
        "responses": {
          "200": {
            "description": "Non-secret local model provider, circuit and live resource status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelGatewayStatus"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/status": {
      "get": {
        "operationId": "getChatStatus",
        "responses": {
          "200": {
            "description": "Persona, memory and active text-turn status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatStatus"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/turns": {
      "post": {
        "operationId": "startChatTurn",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatTurnRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted turn snapshot. Poll the turn resource for completion.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatTurnSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/turns/{turnId}": {
      "get": {
        "operationId": "getChatTurn",
        "parameters": [
          {
            "$ref": "#/components/parameters/TurnId"
          }
        ],
        "responses": {
          "200": {
            "description": "Current or terminal turn snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatTurnSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/turns/{turnId}/cancel": {
      "post": {
        "operationId": "cancelChatTurn",
        "parameters": [
          {
            "$ref": "#/components/parameters/TurnId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Interrupted or already-terminal turn snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatTurnSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/sessions/{sessionId}": {
      "get": {
        "operationId": "replayChatSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bounded successful short-term turn replay.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatReplay"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/sessions/{sessionId}/clear": {
      "post": {
        "operationId": "clearChatSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "const": "clear"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cleared in-memory conversation window and relationship state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatReplay"
                }
              }
            }
          }
        }
      }
    },
    "/v1/errors": {
      "get": {
        "operationId": "getRecentErrors",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent redacted structured error records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRecordPage"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/status": {
      "get": {
        "operationId": "getSafetyStatus",
        "responses": {
          "200": {
            "description": "Loaded capability manifest, operator safety state and verified audit head.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SafetyStatus"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/audit": {
      "get": {
        "operationId": "getSafetyAudit",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent hash-chained safety audit records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SafetyAuditPage"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/evaluate": {
      "post": {
        "operationId": "evaluateCapability",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PolicyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audited allow, ask or deny decision.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyDecision"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/control": {
      "post": {
        "operationId": "applySafetyControl",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OperatorControlRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Effective operator safety state after the control request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperatorControlResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/sanitize": {
      "post": {
        "operationId": "sanitizeInput",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SanitizeInputRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sanitized text and signed sanitation evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SanitizeInputResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/context": {
      "post": {
        "operationId": "createContextBundle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContextBundleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bounded context bundle containing verified sanitized text only.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextBundle"
                }
              }
            }
          }
        }
      }
    },
    "/v1/safety/moderate": {
      "post": {
        "operationId": "moderateContent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModerationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fail-closed moderation decision for a named safety surface.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModerationDecision"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "TurnId": {
        "name": "turnId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "SessionId": {
        "name": "sessionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "service",
          "uptimeSeconds",
          "activeConnections"
        ],
        "properties": {
          "status": {
            "const": "ready"
          },
          "service": {
            "const": "hina-core-runtime"
          },
          "uptimeSeconds": {
            "type": "number",
            "minimum": 0
          },
          "activeConnections": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "Version": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service",
          "buildCommit",
          "controlApi",
          "realtimeProtocol",
          "binaryMediaVersion"
        ],
        "properties": {
          "service": {
            "const": "hina-core-runtime"
          },
          "buildCommit": {
            "type": "string"
          },
          "controlApi": {
            "const": "v1"
          },
          "realtimeProtocol": {
            "const": "hina.realtime.v1"
          },
          "binaryMediaVersion": {
            "const": 1
          }
        }
      },
      "PublicConfig": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "host",
          "port",
          "loopbackOnly",
          "limits"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Numeric loopback address only."
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "loopbackOnly": {
            "const": true
          },
          "limits": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "httpHeaderBytes",
              "controlBodyBytes",
              "textFrameBytes",
              "binaryFrameBytes",
              "connections"
            ],
            "properties": {
              "httpHeaderBytes": {
                "type": "integer",
                "minimum": 1024
              },
              "controlBodyBytes": {
                "type": "integer",
                "minimum": 1024,
                "maximum": 1048576
              },
              "textFrameBytes": {
                "type": "integer",
                "minimum": 1024
              },
              "binaryFrameBytes": {
                "type": "integer",
                "minimum": 26
              },
              "connections": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      },
      "MetricPoint": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "labels",
          "value",
          "count",
          "sum",
          "min",
          "max"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "counter",
              "gauge",
              "histogram"
            ]
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "value": {
            "type": "number"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "sum": {
            "type": "number"
          },
          "min": {
            "type": [
              "number",
              "null"
            ]
          },
          "max": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      },
      "MetricsSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "series",
          "seriesCount",
          "maxSeries"
        ],
        "properties": {
          "series": {
            "type": "array",
            "maxItems": 256,
            "items": {
              "$ref": "#/components/schemas/MetricPoint"
            }
          },
          "seriesCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 256
          },
          "maxSeries": {
            "type": "integer",
            "minimum": 1,
            "maximum": 256
          }
        }
      },
      "ModelGatewayStatus": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "configured",
          "provider",
          "resource",
          "circuit",
          "available"
        ],
        "properties": {
          "configured": {
            "type": "object"
          },
          "provider": {
            "type": "object"
          },
          "resource": {
            "type": "object"
          },
          "circuit": {
            "type": "object"
          },
          "available": {
            "type": "boolean"
          }
        }
      },
      "ChatStatus": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "persona",
          "memory",
          "activeTurns",
          "trackedTurns",
          "outboundPartialStreaming",
          "toolExecution"
        ],
        "properties": {
          "persona": {
            "type": "object"
          },
          "memory": {
            "type": "object"
          },
          "activeTurns": {
            "type": "integer",
            "minimum": 0
          },
          "trackedTurns": {
            "type": "integer",
            "minimum": 0,
            "maximum": 256
          },
          "outboundPartialStreaming": {
            "const": false
          },
          "toolExecution": {
            "const": false
          }
        }
      },
      "ChatTurnRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sessionId",
          "source",
          "text"
        ],
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "source": {
            "enum": [
              "owner.console",
              "authenticated.user",
              "public.chat",
              "viewer.chat"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "ChatTurnSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "turnId",
          "sessionId",
          "correlationId",
          "state",
          "stateHistory",
          "outcome",
          "createdAt",
          "user",
          "assistant",
          "promptVersion",
          "context",
          "toolProposal",
          "errorCode",
          "errorMessage"
        ],
        "properties": {
          "turnId": {
            "type": "string",
            "format": "uuid"
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "correlationId": {
            "type": "string",
            "format": "uuid"
          },
          "state": {
            "enum": [
              "idle",
              "listening",
              "thinking",
              "speaking",
              "interrupted",
              "error"
            ]
          },
          "stateHistory": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "outcome": {
            "enum": [
              "running",
              "completed",
              "interrupted",
              "error"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "type": [
              "string",
              "null"
            ]
          },
          "assistant": {
            "type": [
              "string",
              "null"
            ]
          },
          "promptVersion": {
            "type": [
              "string",
              "null"
            ]
          },
          "context": {
            "type": [
              "object",
              "null"
            ]
          },
          "toolProposal": {
            "type": [
              "object",
              "null"
            ]
          },
          "errorCode": {
            "type": [
              "string",
              "null"
            ]
          },
          "errorMessage": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ChatReplay": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "sessionId",
          "turnCount",
          "relationship"
        ],
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "turnCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 24
          },
          "relationship": {
            "type": "object"
          }
        }
      },
      "ErrorRecord": {
        "type": "object",
        "required": [
          "timestamp",
          "level",
          "component",
          "operation",
          "errorCode",
          "message",
          "correlationId",
          "exceptionType",
          "buildCommit",
          "contractVersion",
          "runtimeProfile",
          "context"
        ],
        "properties": {
          "timestamp": {
            "type": "string"
          },
          "level": {
            "const": "error"
          },
          "component": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "correlationId": {
            "type": "string",
            "format": "uuid"
          },
          "exceptionType": {
            "type": "string"
          },
          "buildCommit": {
            "type": "string"
          },
          "contractVersion": {
            "type": "string"
          },
          "runtimeProfile": {
            "type": "string"
          },
          "context": {
            "type": "object"
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "turnId": {
            "type": "string",
            "format": "uuid"
          },
          "loggingFailed": {
            "type": "boolean"
          }
        }
      },
      "ErrorRecordPage": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "records",
          "count",
          "limit"
        ],
        "properties": {
          "records": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/ErrorRecord"
            }
          },
          "count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        }
      },
      "CapabilitySummary": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "risk",
          "defaultDecision",
          "allowedTrustLevels",
          "featureFlag",
          "rateLimitPerMinute",
          "sessionBudget",
          "expiresAt"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "risk": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "defaultDecision": {
            "enum": [
              "allow",
              "ask",
              "deny"
            ]
          },
          "allowedTrustLevels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "featureFlag": {
            "type": [
              "string",
              "null"
            ]
          },
          "rateLimitPerMinute": {
            "type": "integer",
            "minimum": 1
          },
          "sessionBudget": {
            "type": "integer",
            "minimum": 1
          },
          "expiresAt": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "SafetyState": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "revision",
          "emergencyStopped",
          "muted",
          "featureFlags",
          "revokedCapabilities"
        ],
        "properties": {
          "revision": {
            "type": "integer",
            "minimum": 0
          },
          "emergencyStopped": {
            "type": "boolean"
          },
          "muted": {
            "type": "boolean"
          },
          "featureFlags": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "revokedCapabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SafetyStatus": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "manifest",
          "state",
          "audit",
          "sanitation",
          "moderation"
        ],
        "properties": {
          "manifest": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schemaVersion",
              "manifestId",
              "capabilities"
            ],
            "properties": {
              "schemaVersion": {
                "const": "1.0"
              },
              "manifestId": {
                "type": "string"
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CapabilitySummary"
                }
              }
            }
          },
          "state": {
            "$ref": "#/components/schemas/SafetyState"
          },
          "audit": {
            "type": "object"
          },
          "sanitation": {
            "type": "object"
          },
          "moderation": {
            "type": "object"
          }
        }
      },
      "PolicyRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
