{
  "openapi": "3.1.0",
  "info": {
    "title": "Hina local control plane",
    "version": "1.0.0",
    "description": "Loopback-only read control surface for the Hina core runtime."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8765"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Runtime readiness and bounded connection status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "Build and protocol versions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Version"
                }
              }
            }
          }
        }
      }
    },
    "/v1/config": {
      "get": {
        "operationId": "getPublicConfig",
        "responses": {
          "200": {
            "description": "Non-secret effective transport limits.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicConfig"
                }
              }
            }
          }
        }
      }
    },
    "/v1/metrics": {
      "get": {
        "operationId": "getMetrics",
        "responses": {
          "200": {
            "description": "Bounded in-memory runtime metric snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "/v1/errors": {
      "get": {
        "operationId": "getRecentErrors",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent redacted structured error records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRecordPage"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Health": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "service",
          "uptimeSeconds",
          "activeConnections"
        ],
        "properties": {
          "status": {
            "const": "ready"
          },
          "service": {
            "const": "hina-core-runtime"
          },
          "uptimeSeconds": {
            "type": "number",
            "minimum": 0
          },
          "activeConnections": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "Version": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service",
          "buildCommit",
          "controlApi",
          "realtimeProtocol",
          "binaryMediaVersion"
        ],
        "properties": {
          "service": {
            "const": "hina-core-runtime"
          },
          "buildCommit": {
            "type": "string"
          },
          "controlApi": {
            "const": "v1"
          },
          "realtimeProtocol": {
            "const": "hina.realtime.v1"
          },
          "binaryMediaVersion": {
            "const": 1
          }
        }
      },
      "PublicConfig": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "host",
          "port",
          "loopbackOnly",
          "limits"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Numeric loopback address only."
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "loopbackOnly": {
            "const": true
          },
          "limits": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "httpHeaderBytes",
              "textFrameBytes",
              "binaryFrameBytes",
              "connections"
            ],
            "properties": {
              "httpHeaderBytes": {
                "type": "integer",
                "minimum": 1024
              },
              "textFrameBytes": {
                "type": "integer",
                "minimum": 1024
              },
              "binaryFrameBytes": {
                "type": "integer",
                "minimum": 26
              },
              "connections": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      },
      "MetricPoint": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "labels",
          "value",
          "count",
          "sum",
          "min",
          "max"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "counter",
              "gauge",
              "histogram"
            ]
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "value": {
            "type": "number"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "sum": {
            "type": "number"
          },
          "min": {
            "type": [
              "number",
              "null"
            ]
          },
          "max": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      },
      "MetricsSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "series",
          "seriesCount",
          "maxSeries"
        ],
        "properties": {
          "series": {
            "type": "array",
            "maxItems": 256,
            "items": {
              "$ref": "#/components/schemas/MetricPoint"
            }
          },
          "seriesCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 256
          },
          "maxSeries": {
            "type": "integer",
            "minimum": 1,
            "maximum": 256
          }
        }
      },
      "ErrorRecord": {
        "type": "object",
        "required": [
          "timestamp",
          "level",
          "component",
          "operation",
          "errorCode",
          "message",
          "correlationId",
          "exceptionType",
          "buildCommit",
          "contractVersion",
          "runtimeProfile",
          "context"
        ],
        "properties": {
          "timestamp": {
            "type": "string"
          },
          "level": {
            "const": "error"
          },
          "component": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "correlationId": {
            "type": "string",
            "format": "uuid"
          },
          "exceptionType": {
            "type": "string"
          },
          "buildCommit": {
            "type": "string"
          },
          "contractVersion": {
            "type": "string"
          },
          "runtimeProfile": {
            "type": "string"
          },
          "context": {
            "type": "object"
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "turnId": {
            "type": "string",
            "format": "uuid"
          },
          "loggingFailed": {
            "type": "boolean"
          }
        }
      },
      "ErrorRecordPage": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "records",
          "count",
          "limit"
        ],
        "properties": {
          "records": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/ErrorRecord"
            }
          },
          "count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        }
      }
    }
  }
}
