{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-hina.local/safety/capability-manifest.v1.schema.json",
  "title": "HinaCapabilityManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "capabilities"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{0,127}$"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/capability"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "risk",
        "defaultDecision",
        "allowedTrustLevels",
        "featureFlag",
        "rateLimitPerMinute",
        "sessionBudget",
        "expiresAt"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]{0,127}$"
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "defaultDecision": {
          "enum": [
            "allow",
            "ask",
            "deny"
          ]
        },
        "allowedTrustLevels": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "authenticated",
              "owner",
              "public",
              "trusted_local",
              "untrusted"
            ]
          }
        },
        "featureFlag": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "memoryPromotion",
            "perception",
            "gameAction",
            "streamOutput",
            null
          ]
        },
        "rateLimitPerMinute": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "sessionBudget": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "expiresAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
