{
  "name": "hina-ai",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first Vietnamese AI VTuber",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "check:m00": "uv run --frozen python tools/dev/validate_m00.py && uv run --frozen python -m unittest discover -s tests -p \"test_*.py\" && node tools/dev/check-node-workspace.mjs",
    "smoke:m01-s2": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M01S2Demo.ps1",
    "smoke:m01-s3": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M01S3Demo.ps1",
    "smoke:m01-s4": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M01S4Demo.ps1",
    "smoke:m01-s5": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M01S5Demo.ps1",
    "smoke:m01-s6": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M01S6Demo.ps1",
    "report:errors": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Collect-HinaErrorReport.ps1",
    "smoke:dev-console": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Start-HinaDevConsole.ps1 -Port 0 -NoBrowser -StartupCheck",
    "smoke:m04-stt": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M04RealSttSmoke.ps1",
    "smoke:m05-tts": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M05RealTtsSmoke.ps1",
    "start:control": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Start-HinaControlPlane.ps1",
    "start:dev-console": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Start-HinaDevConsole.ps1",
    "start:desktop": "pnpm --filter @hina/desktop build && pnpm --filter @hina/desktop start",
    "build:desktop": "pnpm --filter @hina/desktop build",
    "test:desktop": "pnpm --filter @hina/desktop test",
    "smoke:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-M07DesktopSmoke.ps1",
    "test:lifecycle:100": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Run-LifecycleCycles.ps1 --cycles 100",
    "test:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-FastUnit.ps1",
    "test:safety": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-SafetyUnit.ps1",
    "test:text-brain": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-TextBrainUnit.ps1",
    "test:memory": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-MemoryUnit.ps1",
    "test:avatar": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-AvatarUnit.ps1",
    "test:speech": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/dev/Invoke-SpeechUnit.ps1",
    "test:contracts": "uv run --frozen python tools/contracts/generate_models.py --check && pnpm --filter @hina/contracts check:generated && uv run --frozen python -m unittest discover -s tests/contracts -p \"test_*.py\" && pnpm --filter @hina/contracts test",
    "test:contracts:repeat": "uv run --frozen python tools/contracts/repeat_gate.py --runs 20 --require-clean",
    "sbom": "uv run --frozen python tools/sbom/generate_sbom.py"
  }
}
